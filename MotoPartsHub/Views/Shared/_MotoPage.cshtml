    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/angular.min.js"></script>
    <script src="~/Scripts/MetaScripts/Module.js"></script>
    <script src="~/Scripts/MetaScripts/Service.js"></script>
    <script src="~/Scripts/MetaScripts/Controller.js"></script>
