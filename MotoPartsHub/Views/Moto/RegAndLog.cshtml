@{
    Layout = "~/Views/Shared/_MotoPage.cshtml";
    ViewBag.Title = "Register / Login - MotoParts";
}

<style>
    body {
        background: #f5f5f5;
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .top-nav {
        background: #bf360c;
        padding: 0 24px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        flex-shrink: 0;
    }

        .top-nav .brand {
            color: #fff;
            font-size: 20px;
            font-weight: 700;
            text-decoration: none;
        }

            .top-nav .brand span {
                color: #ffccbc;
            }

    .back-link {
        color: rgba(255,255,255,0.8);
        font-size: 13px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 4px;
    }

        .back-link:hover {
            color: #fff;
        }

        .back-link i {
            font-size: 16px;
        }

    .page-wrap {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 28px 16px 80px;
    }

    .page-logo {
        text-align: center;
        margin-bottom: 24px;
    }

        .page-logo .icon-circle {
            width: 64px;
            height: 64px;
            background: #bf360c;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            box-shadow: 0 4px 12px rgba(191,54,12,0.3);
        }

            .page-logo .icon-circle i {
                font-size: 32px;
                color: #fff;
            }

        .page-logo h5 {
            font-size: 18px;
            font-weight: 700;
            color: #212121;
            margin: 0 0 2px;
        }

        .page-logo p {
            font-size: 12px;
            color: #9e9e9e;
            margin: 0;
        }

    /* FLIP */
    .flip-container {
        perspective: 1000px;
        width: 100%;
        max-width: 420px;
        margin-bottom: 24px;
    }

    .flipper {
        transition: transform 0.6s;
        transform-style: preserve-3d;
        position: relative;
        min-height: 560px;
    }

    .flip-container.flipped .flipper {
        transform: rotateY(180deg);
    }

    .front, .back {
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
    }

    .back {
        transform: rotateY(180deg);
    }

    /* CARD */
    .auth-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .card-header {
        background: #bf360c;
        padding: 18px 24px;
    }

        .card-header h5 {
            color: #fff;
            font-weight: 700;
            font-size: 17px;
            margin: 0 0 2px;
        }

        .card-header p {
            color: rgba(255,255,255,0.7);
            font-size: 12px;
            margin: 0;
        }

    .card-body {
        padding: 24px;
    }

    .input-field input {
        color: #212121 !important;
    }

        .input-field input:focus {
            border-bottom: 1px solid #bf360c !important;
            box-shadow: 0 1px 0 0 #bf360c !important;
        }

    .input-field label {
        color: #9e9e9e !important;
    }

        .input-field label.active {
            color: #bf360c !important;
        }

    .input-field .prefix {
        color: #bdbdbd !important;
    }

        .input-field .prefix.active {
            color: #bf360c !important;
        }

    .input-field i.prefix.clickable {
        cursor: pointer;
        pointer-events: auto;
    }

    .name-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .section-label {
        font-size: 10px;
        font-weight: 700;
        color: #bdbdbd;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 12px 0 0;
        padding-bottom: 6px;
        border-bottom: 1px solid #f5f5f5;
    }

    .char-hint {
        font-size: 10px;
        color: #bdbdbd;
        text-align: right;
        margin-top: -8px;
        margin-bottom: 4px;
    }

        .char-hint.warn {
            color: #e65100;
        }

    .btn-primary {
        width: 100%;
        background: #bf360c;
        color: #fff;
        border: none;
        border-radius: 4px;
        height: 42px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 10px;
        transition: background 0.2s;
    }

        .btn-primary:hover {
            background: #870000;
        }

    .btn-secondary {
        width: 100%;
        background: #f5f5f5;
        color: #757575;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        height: 42px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 10px;
        transition: background 0.2s;
    }

        .btn-secondary:hover {
            background: #e0e0e0;
        }

    .btn-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

        .btn-row .btn-primary, .btn-row .btn-secondary {
            margin-top: 0;
        }

    .success-box {
        background: #e8f5e9;
        border: 1px solid #a5d6a7;
        border-radius: 6px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 14px;
        font-size: 13px;
        color: #2e7d32;
    }

        .success-box i {
            font-size: 18px;
            color: #43a047;
        }

    .switch-text {
        text-align: center;
        margin-top: 16px;
        font-size: 13px;
        color: #9e9e9e;
    }

        .switch-text a {
            color: #bf360c;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }

            .switch-text a:hover {
                text-decoration: underline;
            }

    /* FOOTER */
    .site-footer {
        background: #212121;
        color: #757575;
        text-align: center;
        padding: 16px 24px;
        font-size: 12px;
        flex-shrink: 0;
    }

        .site-footer span {
            color: #bf360c;
            font-weight: 600;
        }

    @@media (max-width: 480px) {
        .name-row {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .card-body {
            padding: 18px;
        }

        .flipper {
            min-height: 620px;
        }

        .page-wrap {
            padding: 20px 12px 80px;
        }
    }
</style>

<!-- NAVBAR -->
<nav class="top-nav">
    <a class="brand" href="/Moto/LandingPage">Moto<span>Parts</span></a>
    <a href="/Moto/LandingPage" class="back-link"><i class="material-icons">arrow_back</i> Back to Catalog</a>
</nav>

<div class="page-wrap">

    <!-- LOGO -->
    <div class="page-logo">
        <div class="icon-circle"><i class="material-icons">two_wheeler</i></div>
        <h5>MotoParts</h5>
        <p>Motorcycle Parts Inventory &amp; Catalog System</p>
    </div>

    <!-- FLIP CARD -->
    <div class="flip-container" ng-class="{'flipped': isRegistered}">
        <div class="flipper">

            <!-- FRONT: REGISTER -->
            <div class="front">
                <div class="auth-card">
                    <div class="card-header">
                        <h5>Create Account</h5>
                        <p>Fill in your details to get started</p>
                    </div>
                    <div class="card-body">

                        <div class="success-box" ng-show="showLoginBtn">
                            <i class="material-icons">check_circle</i>
                            Registered! You can now log in.
                        </div>

                        <div class="section-label">Personal Info</div>
                        <div class="name-row">
                            <div class="input-field">
                                <i class="material-icons prefix">person</i>
                                <input type="text" id="fname" ng-model="user.fname" maxlength="32" />
                                <label for="fname">First Name</label>
                            </div>
                            <div class="input-field">
                                <i class="material-icons prefix">person_outline</i>
                                <input type="text" id="lname" ng-model="user.lname" maxlength="32" />
                                <label for="lname">Last Name</label>
                            </div>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">phone</i>
                            <input type="tel" id="phone" ng-model="user.phone"
                                   maxlength="11"
                                   ng-keypress="numbersOnly($event)" />
                            <label for="phone">Phone Number</label>
                        </div>

                        <div class="section-label">Account Details</div>

                        <div class="input-field">
                            <i class="material-icons prefix">account_circle</i>
                            <input type="text" id="username" ng-model="user.username" />
                            <label for="username">Username</label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix clickable" ng-click="showPass = !showPass">
                                {{ showPass ? 'visibility' : 'visibility_off' }}
                            </i>
                            <input type="{{ showPass ? 'text' : 'password' }}" id="password" ng-model="user.password" maxlength="32" />
                            <label for="password">Password</label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix clickable" ng-click="showConfirmPass = !showConfirmPass">
                                {{ showConfirmPass ? 'visibility' : 'visibility_off' }}
                            </i>
                            <input type="{{ showConfirmPass ? 'text' : 'password' }}" id="confirmPassword" ng-model="user.confirmPassword" maxlength="32" />
                            <label for="confirmPassword">Confirm Password</label>
                        </div>

                        <div class="btn-row" ng-hide="showLoginBtn">
                            <button class="btn-primary" ng-click="register()">Register</button>
                            <button class="btn-secondary" ng-click="cancelFunc()">Cancel</button>
                        </div>

                        <button class="btn-primary" ng-show="showLoginBtn" ng-click="goToLogin()">Go to Login</button>

                        <div class="switch-text" ng-hide="showLoginBtn">
                            Already have an account? <a ng-click="goToLogin()">Sign in</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BACK: LOGIN -->
            <div class="back">
                <div class="auth-card">
                    <div class="card-header">
                        <h5>Welcome Back!</h5>
                        <p>Sign in to your account</p>
                    </div>
                    <div class="card-body">

                        <div class="input-field">
                            <i class="material-icons prefix">account_circle</i>
                            <input type="text" id="loginUsername" ng-model="login.username" maxlength="32" />
                            <label for="loginUsername">Username</label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">lock</i>
                            <input type="password" id="loginPassword" ng-model="login.password" maxlength="32" />
                            <label for="loginPassword">Password</label>
                        </div>

                        <button class="btn-primary" ng-click="checkLogin()">Sign In</button>

                        <div class="switch-text">
                            Don't have an account? <a ng-click="goToRegister()">Register here</a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- FOOTER -->
<footer class="site-footer">
    &copy; 2026 <span>MotoPartsHub</span> &mdash; Motorcycle Parts Inventory &amp; Catalog System. All rights reserved.
</footer>
