@{
    Layout = "~/Views/Shared/_MotoPage.cshtml";
}

<style>
    body {
        margin: 0;
        background: #f5f5f5;
        color: #212121;
    }

    .top-nav {
        background: #bf360c;
        height: 56px;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        box-shadow: 0 2px 6px rgba(0,0,0,.2);
    }

    .brand {
        color: #fff;
        text-decoration: none;
        font-size: 20px;
        font-weight: 700;
    }

        .brand span,
        .nav-links a:first-child {
            color: #ffccbc;
        }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 20px;
    }

        .nav-links a {
            color: #fff;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

    .hero-section {
        background: #bf360c;
        color: #fff;
        text-align: center;
        padding: 100px 20px 60px;
    }

        .hero-section h1 {
            margin: 0 0 12px;
            font-size: 36px;
            font-weight: 800;
            line-height: 1.2;
        }

            .hero-section h1 span {
                color: #ffccbc;
            }

        .hero-section p {
            max-width: 520px;
            margin: 0 auto 28px;
            font-size: 15px;
            line-height: 1.6;
            color: rgba(255,255,255,.85);
        }

    .hero-btns {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

        .hero-btns a {
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            padding: 12px 28px;
            border-radius: 4px;
            transition: .2s;
        }

    .btn-browse {
        background: #fff;
        color: #bf360c;
    }

        .btn-browse:hover {
            background: #ffccbc;
        }

    .btn-create {
        color: #fff;
        border: 2px solid rgba(255,255,255,.7);
        background: transparent;
    }

        .btn-create:hover {
            background: rgba(255,255,255,.1);
        }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        background: #fff;
        border-bottom: 1px solid #e0e0e0;
    }

    .stat-box {
        text-align: center;
        padding: 20px 16px;
        border-right: 1px solid #e0e0e0;
    }

        .stat-box:last-child {
            border-right: none;
        }

    .num {
        font-size: 26px;
        font-weight: 800;
        color: #bf360c;
    }

    .lbl {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #9e9e9e;
    }

    .catalog-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 24px 48px;
    }

    .catalog-title {
        margin-bottom: 16px;
        font-size: 18px;
        font-weight: 700;
    }

        .catalog-title span {
            color: #bf360c;
        }

    .search-bar-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        padding: 0 14px;
        margin-bottom: 12px;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }

        .search-bar-wrap i {
            color: #9e9e9e;
        }

        .search-bar-wrap input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 12px 0;
            font-size: 14px;
        }

    .filter-row,
    .chips-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .filter-row {
        margin-bottom: 20px;
    }

    .chips-row {
        margin-bottom: 20px;
    }

    .filter-select {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        padding: 8px 14px;
        font-size: 13px;
        outline: none;
    }

    .cat-chip {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 20px;
        padding: 5px 16px;
        font-size: 12px;
        font-weight: 600;
        color: #757575;
        cursor: pointer;
    }

        .cat-chip.active {
            background: #bf360c;
            border-color: #bf360c;
            color: #fff;
        }

    .results-count {
        margin-bottom: 16px;
        font-size: 12px;
        color: #9e9e9e;
    }

    .parts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 16px;
    }

    .part-card {
        background: #fff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        transition: .2s;
    }

        .part-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,.12);
        }

    .card-img {
        height: 100px;
        background: #fbe9e7;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        .card-img i {
            font-size: 40px;
            color: #bf360c;
            opacity: .4;
        }

    .stock-tag {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .tag-in {
        background: #e8f5e9;
        color: #388e3c;
    }

    .tag-low {
        background: #fff3e0;
        color: #e65100;
    }

    .tag-out {
        background: #ffebee;
        color: #c62828;
    }

    .card-body {
        padding: 12px;
    }

    .card-cat {
        margin-bottom: 3px;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #bf360c;
    }

    .card-name {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 2px;
    }

    .card-sku {
        font-size: 10px;
        color: #bdbdbd;
        margin-bottom: 6px;
    }

    .card-price {
        font-size: 16px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .card-shop {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: #9e9e9e;
        margin-bottom: 10px;
    }

        .card-shop i {
            font-size: 12px;
        }

    .card-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
    }

    .btn-details,
    .btn-inquire,
    .btn-close-modal,
    .btn-inq-modal {
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        padding: 7px 8px;
        cursor: pointer;
        transition: .2s;
    }

    .btn-details {
        background: transparent;
        border: 1px solid #e0e0e0;
        color: #757575;
    }

        .btn-details:hover {
            border-color: #bf360c;
            color: #bf360c;
        }

    .btn-inquire,
    .btn-inq-modal {
        background: #bf360c;
        border: none;
        color: #fff;
    }

        .btn-inquire:hover,
        .btn-inq-modal:hover {
            background: #870000;
        }

    .no-results {
        grid-column: 1 / -1;
        text-align: center;
        padding: 48px;
        color: #bdbdbd;
    }

        .no-results i {
            display: block;
            font-size: 48px;
            margin-bottom: 10px;
        }

    #detailModal {
        max-width: 540px;
        max-height: 85vh;
        overflow-y: auto;
        border-radius: 8px;
        background: #fff;
    }

    .modal-header {
        background: #bf360c;
        padding: 18px 22px;
    }

        .modal-header h5 {
            margin: 0 0 4px;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
        }

        .modal-header p {
            margin: 0;
            color: rgba(255,255,255,.75);
            font-size: 12px;
        }

    .modal-body {
        padding: 20px 22px;
    }

    .modal-price {
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .modal-desc {
        margin-bottom: 16px;
        font-size: 13px;
        line-height: 1.5;
        color: #757575;
    }

    .modal-sec {
        margin: 14px 0 8px;
        padding-bottom: 6px;
        border-bottom: 1px solid #f5f5f5;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #9e9e9e;
    }

    .spec-table {
        width: 100%;
        border-collapse: collapse;
    }

        .spec-table td {
            padding: 7px 4px;
            border-bottom: 1px solid #f5f5f5;
            font-size: 13px;
        }

            .spec-table td:first-child {
                width: 44%;
                color: #9e9e9e;
            }

            .spec-table td:last-child {
                font-weight: 500;
            }

    .feat-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .feat-chip {
        background: #fbe9e7;
        border: 1px solid #ffccbc;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 11px;
        font-weight: 600;
        color: #bf360c;
    }

    #detailModal .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 12px 22px;
        background: #fafafa;
        border-top: 1px solid #f0f0f0;
    }

    .btn-close-modal {
        background: #f5f5f5;
        border: 1px solid #e0e0e0;
        color: #757575;
    }

        .btn-close-modal:hover {
            background: #e0e0e0;
        }

    @@media (max-width: 600px) {
        .top-nav {
            padding: 0 14px;
        }

        .hero-section {
            padding: 80px 20px 40px;
        }

            .hero-section h1 {
                font-size: 26px;
            }

        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .catalog-wrapper {
            padding: 20px 14px 40px;
        }
    }
    .site-footer {
        background: #212121;
        color: #757575;
        text-align: center;
        padding: 16px 24px;
        font-size: 12px;
        flex-shrink: 0;
    }

        .site-footer span {
            color: #bf360c;
            font-weight: 600;
        }
</style>

<nav class="top-nav">
    <a class="brand" href="/Moto/LandingPage">Moto<span>Parts</span></a>

    <div class="nav-links" ng-if="loggedInUser.Username !== 'guest'">
        <a href="/Rider/DashboardPage">Dashboard</a>
        <a ng-click="logout()">Logout</a>
    </div>
</nav>

<nav class="top-nav">
    <a class="brand" href="/Moto/LandingPage">Moto<span>Parts</span></a>

    <div class="nav-links" ng-if="loggedInUser.Username !== 'guest'">
        <a href="/Rider/DashboardPage">Dashboard</a>
        <a ng-click="logout()">Logout</a>
    </div>

    <div class="nav-links" ng-if="loggedInUser.Username === 'guest'">
         <a href="/Moto/RegAndLog?mode=login">Login</a>
    </div>
</nav>

<section class="hero-section">
    <h1>Find the <span>Right Part</span><br />for Your Ride</h1>
    <p>Browse verified motorcycle parts from trusted local shops. Search by model, category, or part number.</p>

    <div class="hero-btns">
        <a href="#catalog" class="btn-browse">Browse Catalog</a>
        <a href="/Moto/RegAndLog" class="btn-create">Create Account</a>
    </div>
</section>

<div class="stats-row">
    <div class="stat-box">
        <div class="num">10+</div>
        <div class="lbl">Parts Listed</div>
    </div>
    <div class="stat-box">
        <div class="num">4</div>
        <div class="lbl">Partner Shops</div>
    </div>
    <div class="stat-box">
        <div class="num">7</div>
        <div class="lbl">Categories</div>
    </div>
    <div class="stat-box">
        <div class="num">24/7</div>
        <div class="lbl">Online Access</div>
    </div>
</div>

<div class="catalog-wrapper" id="catalog">
    <div class="catalog-title">Parts <span>Catalog</span></div>

    <div class="search-bar-wrap">
        <i class="material-icons">search</i>
        <input type="text" ng-model="searchQuery" placeholder="Search parts, SKU, brand, or model..." />
    </div>

    <div class="filter-row">
        <select class="filter-select" ng-model="selectedCategory" ng-options="c for c in categories"></select>
        <select class="filter-select" ng-model="sortOption">
            <option value="name">Sort: A-Z</option>
            <option value="price_asc">Price: Low to High</option>
            <option value="price_desc">Price: High to Low</option>
        </select>
    </div>

    <div class="chips-row">
        <button type="button"
                class="cat-chip"
                ng-repeat="cat in categories"
                ng-class="{active: selectedCategory === cat}"
                ng-click="selectCategory(cat)">
            {{ cat }}
        </button>
    </div>

    <div class="results-count">{{ filteredParts().length }} results found</div>

    <div class="parts-grid">
        <div class="part-card" ng-repeat="part in filteredParts()">
            <div class="card-img">
                <i class="material-icons">{{ part.icon }}</i>

                <span class="stock-tag" ng-class="{'tag-in': part.stock > 5, 'tag-low': part.stock > 0 && part.stock <= 5, 'tag-out': part.stock === 0}">
                    {{ part.stock === 0 ? 'Out of Stock' : (part.stock <= 5 ? 'Low Stock' : 'In Stock') }}
                </span>
            </div>

            <div class="card-body">
                <div class="card-cat">{{ part.category }}</div>
                <div class="card-name">{{ part.name }}</div>
                <div class="card-sku">SKU: {{ part.sku }}</div>
                <div class="card-price">₱{{ part.price | number:2 }}</div>
                <div class="card-shop">
                    <i class="material-icons">store</i>
                    {{ part.shop }}
                </div>

                <div class="card-actions">
                    <button type="button" class="btn-details" ng-click="viewDetails(part)">View Details</button>
                    <button type="button" class="btn-inquire" ng-click="inquirePart(part)">Inquire</button>
                </div>
            </div>
        </div>

        <div class="no-results" ng-show="filteredParts().length === 0">
            <i class="material-icons">search_off</i>
            <p>No parts found. Try a different keyword or category.</p>
        </div>
    </div>
</div>

<div id="detailModal" class="modal">
    <div class="modal-content" ng-if="selectedPart" style="padding:0;">
        <div class="modal-header">
            <h5>{{ selectedPart.name }}</h5>
            <p>{{ selectedPart.brand }} &bull; {{ selectedPart.category }}</p>
        </div>

        <div class="modal-body">
            <div class="modal-price">₱{{ selectedPart.price | number:2 }}</div>
            <div class="modal-desc">{{ selectedPart.shortDesc }}</div>

            <div class="modal-sec">Technical Specifications</div>
            <table class="spec-table">
                <tr ng-repeat="(key, val) in selectedPart.specs">
                    <td>{{ key }}</td>
                    <td>{{ val }}</td>
                </tr>
            </table>

            <div class="modal-sec">Features</div>
            <div class="feat-list">
                <span class="feat-chip" ng-repeat="f in selectedPart.features">{{ f }}</span>
            </div>
        </div>
    </div>

    <div class="modal-footer" ng-if="selectedPart">
        <button type="button" class="btn-close-modal modal-close">Close</button>
        <button type="button" class="btn-inq-modal" ng-click="inquirePart(selectedPart)">Inquire Now</button>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var modals = document.querySelectorAll(".modal");
        M.Modal.init(modals);
    });
</script>

<footer class="site-footer">
    &copy; 2026 <span>MotoPartsHub</span> &mdash; Motorcycle Parts Inventory &amp; Catalog System. All rights reserved.
</footer>